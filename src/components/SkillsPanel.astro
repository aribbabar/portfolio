---
import Panel from './Panel.astro';
import PixelIcon from './PixelIcon.astro';
import cloudIcon from '../assets/cloud-green.svg?url';
import codeBlockIcon from '../assets/code-block-green.svg?url';
import cubeIcon from '../assets/cube-green.svg?url';
import gamepadIcon from '../assets/gamepad.svg?url';
import serverIcon from '../assets/server-green.svg?url';
import starAssetIcon from '../assets/star-green.svg?url';
import terminalIcon from '../assets/terminal-green.svg?url';

const starIcon = '/pixelarticons/star.svg';

const groups = [
	{
		title: 'Languages',
		icon: codeBlockIcon,
		items: ['TypeScript', 'JavaScript', 'Python', 'SQL'],
	},
	{
		title: 'Frontend',
		icon: cubeIcon,
		items: ['React', 'Next.js', 'Astro', 'Tailwind CSS'],
	},
	{
		title: 'Backend',
		icon: serverIcon,
		items: ['Node.js', 'Express', 'Fastify', 'PostgreSQL'],
	},
	{
		title: 'Tools',
		icon: terminalIcon,
		items: ['Git', 'Docker', 'VS Code', 'Postman'],
	},
	{
		title: 'Cloud / DevOps',
		icon: cloudIcon,
		items: ['AWS', 'Vercel', 'Nginx', 'GitHub Actions'],
	},
	{
		title: 'Extras',
		icon: starAssetIcon,
		items: ['Socket.io', 'Prisma', 'OpenAI API', 'and more...'],
	},
];
---

<Panel title="Tech Arsenal" eyebrow="System.Skills" class="skills-panel" id="skills">
	<p slot="intro" class="intro">The tools I use to build, break, and ship things.</p>
	<div class="gamepad-mark" aria-hidden="true">
		<img src={gamepadIcon} class="gamepad-icon" alt="" loading="lazy" />
	</div>
	<div class="skills-grid">
		{
			groups.map((group) => (
				<article class="skill-box">
					<div class="skill-icon">
						<img src={group.icon} alt="" width="28" height="28" loading="lazy" />
					</div>
					<div>
						<h3 class={group.tone}>{group.title}</h3>
						<ul>
							{group.items.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</div>
				</article>
			))
		}
	</div>
	<p class="learning"><PixelIcon src={starIcon} /> Always learning. Currently: better decisions.</p>
</Panel>

<style>
	.skills-panel {
		grid-column: 1 / -1;
	}

	.gamepad-mark,
	.skills-grid,
	.learning {
		position: relative;
		z-index: 1;
	}

	.gamepad-mark {
		position: absolute;
		top: clamp(22px, 2.2vw, 42px);
		right: clamp(22px, 2.2vw, 42px);
		width: 58px;
		height: 36px;
		pointer-events: none;
	}

	.gamepad-icon {
		position: absolute;
		right: 0;
		top: 0;
		display: block;
		width: 58px;
		height: auto;
		filter: drop-shadow(0 0 14px rgba(95, 230, 255, 0.24));
		image-rendering: pixelated;
	}

	.skills-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 12px;
	}

	.skill-box {
		display: grid;
		grid-template-columns: 48px 1fr;
		gap: 16px;
		min-height: 112px;
		padding: 15px 16px;
		border: 1px solid rgba(148, 183, 220, 0.25);
		border-radius: 5px;
		background: rgba(5, 12, 22, 0.78);
		clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
		transition:
			border-color 160ms ease,
			transform 160ms ease;
	}

	.skill-box:hover {
		border-color: rgba(95, 230, 255, 0.52);
		transform: translateY(-2px);
	}

	.skill-icon {
		display: grid;
		place-items: center;
		width: 42px;
		aspect-ratio: 1;
		border: 1px solid rgba(94, 255, 181, 0.4);
		border-radius: 5px;
		color: var(--green);
		background: rgba(94, 255, 181, 0.07);
	}

	.skill-icon img {
		display: block;
		width: 28px;
		height: auto;
		filter: drop-shadow(0 0 10px rgba(94, 255, 181, 0.2));
	}

	h3 {
		margin: 0 0 10px;
		color: var(--text);
		font-size: clamp(0.68rem, 0.74vw, 0.82rem);
		line-height: 1;
		text-transform: uppercase;
	}

	h3::after {
		display: block;
		width: 28px;
		height: 1px;
		margin-top: 9px;
		content: "";
		background: currentColor;
		box-shadow: 7px 0 0 currentColor, 14px 0 0 currentColor;
	}

	ul {
		display: grid;
		gap: 7px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	li {
		color: #d4dfec;
		font-size: clamp(0.64rem, 0.69vw, 0.78rem);
	}

	.learning {
		display: flex;
		align-items: center;
		gap: 12px;
		margin: 22px 0 0;
		color: var(--faint);
		font-size: clamp(0.64rem, 0.7vw, 0.78rem);
		text-transform: uppercase;
	}

	.learning :global(.pixel-icon) {
		--pixel-icon-size: 24px;
		color: var(--green);
	}

	@media (max-width: 1420px) {
		.skills-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 1180px) {
		.skills-panel {
			grid-column: auto;
			grid-row: auto;
		}
	}

	@media (max-width: 580px) {
		.skills-grid {
			grid-template-columns: 1fr;
		}

		.gamepad-mark {
			display: none;
		}
	}
</style>
