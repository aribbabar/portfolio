<canvas class="hero-waves" data-hero-waves aria-hidden="true"></canvas>

<style>
	.hero-waves {
		position: absolute;
		inset: 0;
		z-index: 1;
		width: 100%;
		height: 100%;
		background:
			radial-gradient(ellipse at 50% 94%, rgba(39, 75, 122, 0.16), transparent 46%),
			linear-gradient(180deg, transparent 48%, rgba(2, 5, 12, 0.54) 100%);
		contain: strict;
		pointer-events: none;
	}
</style>

<script>
	const canvases = document.querySelectorAll<HTMLCanvasElement>('[data-hero-waves]');
	const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	canvases.forEach((canvas) => {
		const context = canvas.getContext('2d', { alpha: true });
		const host = canvas.closest<HTMLElement>('.hero-panel');

		if (!context || !host) {
			return;
		}

		let width = 0;
		let height = 0;
		let dpr = 1;
		let raf = 0;
		let start = performance.now();
		let lastFrame = 0;
		let isVisible = true;
		let reduce = reducedMotion.matches;
		const frameInterval = 1000 / 28;

		const pointer = {
			x: 0,
			y: 0,
			targetX: 0,
			targetY: 0,
		};

		const noise = (value: number) => {
			const wave = Math.sin(value * 12.9898) * 43758.5453;

			return wave - Math.floor(wave);
		};

		const layers = [
			{
				rows: 9,
				columns: 260,
				horizon: 0.47,
				reach: 0.39,
				amplitude: 22,
				speed: 0.3,
				frequency: 1.55,
				secondaryFrequency: 3.6,
				pointAlpha: 0.44,
				parallax: 10,
				spacingJitter: 2,
				size: 0.42,
				connectEvery: 0,
			},
			{
				rows: 10,
				columns: 300,
				horizon: 0.55,
				reach: 0.41,
				amplitude: 38,
				speed: 0.4,
				frequency: 1.7,
				secondaryFrequency: 3.8,
				pointAlpha: 0.72,
				parallax: 18,
				spacingJitter: 2.35,
				size: 0.54,
				connectEvery: 8,
			},
			{
				rows: 9,
				columns: 340,
				horizon: 0.62,
				reach: 0.4,
				amplitude: 54,
				speed: 0.48,
				frequency: 1.35,
				secondaryFrequency: 3.25,
				pointAlpha: 0.96,
				parallax: 28,
				spacingJitter: 2.75,
				size: 0.68,
				connectEvery: 7,
			},
		];

		const resize = () => {
			const rect = host.getBoundingClientRect();
			width = Math.max(1, Math.floor(rect.width));
			height = Math.max(1, Math.floor(rect.height));
			dpr = 1;

			canvas.width = Math.floor(width * dpr);
			canvas.height = Math.floor(height * dpr);
			canvas.style.width = `${width}px`;
			canvas.style.height = `${height}px`;
			context.setTransform(dpr, 0, 0, dpr, 0, 0);
			draw(reduce ? start + 5400 : performance.now());
		};

		const rgba = (color: number[], alpha: number) =>
			`rgba(${color[0]}, ${color[1]}, ${color[2]}, ${alpha})`;

		const colorFor = (x: number, alpha: number) => {
			const mix = Math.min(1, Math.max(0, x / Math.max(width, 1)));
			const cyan = [0, 205, 255];
			const blue = [49, 112, 255];
			const purple = [188, 52, 255];
			const midMix = Math.min(1, mix * 1.6);
			const endMix = Math.max(0, (mix - 0.42) / 0.58);
			const base = cyan.map((channel, index) => channel + (blue[index] - channel) * midMix);
			const color = base.map((channel, index) => channel + (purple[index] - channel) * endMix);

			return rgba(color, alpha);
		};

		const colorBucketFor = (x: number, bucketCount: number) =>
			Math.min(bucketCount - 1, Math.max(0, Math.floor((x / Math.max(width, 1)) * bucketCount)));

		const pointFor = (
			layer: (typeof layers)[number],
			rowIndex: number,
			columnIndex: number,
			time: number,
		) => {
			const row = rowIndex / (layer.rows - 1);
			const spacingNoise = noise(rowIndex * 19.31 + columnIndex * 4.73);
			const cluster = Math.sin(columnIndex * 0.19 + rowIndex * 1.7) * 0.5 + 0.5;
			const tightCluster = cluster > 0.58 ? Math.sin(columnIndex * 0.76 + rowIndex) * 0.7 : 0;
			const column =
				(columnIndex +
					(spacingNoise - 0.5) * layer.spacingJitter -
					tightCluster) /
				(layer.columns - 1);
			const depth = row ** 1.9;
			const horizonY = height * layer.horizon;
			const centerX =
				width * 0.5 +
				pointer.x * layer.parallax * (0.2 + depth) +
				Math.sin(row * 8.5 + time * 0.12) * 18 * depth;
			const visibleWidth = width * (0.62 + depth * 1.15);
			const x = centerX + (column - 0.5) * visibleWidth;
			const baseY = horizonY + height * layer.reach * depth;
			const scale = 0.22 + depth * 0.92;
			const crest = Math.sin(row * Math.PI * 2.7 + time * 0.18) * 0.55;
			const phaseA =
				time * layer.speed +
				column * Math.PI * layer.frequency +
				row * (3.6 + crest);
			const phaseB =
				time * layer.speed * 0.84 +
				column * Math.PI * layer.secondaryFrequency -
				row * 4.2;
			const phaseC = time * layer.speed * 0.52 + (column - row * 0.12) * Math.PI * 0.86;
			const swell =
				Math.sin(phaseA) * layer.amplitude * scale +
				Math.cos(phaseB) * layer.amplitude * 0.32 * scale +
				Math.sin(phaseC) * layer.amplitude * 0.18 * scale;
			const rowLift = Math.sin(time * 0.2 + row * 5.8) * layer.amplitude * 0.2 * depth;

			return {
				x,
				y: baseY + swell + rowLift + pointer.y * layer.parallax * 0.45 * scale,
				depth,
				noise: spacingNoise,
			};
		};

		const drawLayer = (layer: (typeof layers)[number], time: number) => {
			const bucketCount = 14;
			const dimDots = Array.from({ length: bucketCount }, () => new Path2D());
			const midDots = Array.from({ length: bucketCount }, () => new Path2D());
			const brightDots = Array.from({ length: bucketCount }, () => new Path2D());
			const glowDots = Array.from({ length: bucketCount }, () => new Path2D());
			const connectors = new Path2D();

			for (let row = 0; row < layer.rows; row += 1) {
				let previousPoint: ReturnType<typeof pointFor> | undefined;

				for (let column = 0; column < layer.columns; column += 1) {
					const point = pointFor(layer, row, column, time);
					const variation = noise(row * 41.7 + column * 13.13);
					const depthScale = 0.45 + point.depth * 1.45;
					const cluster = Math.sin(column * 0.19 + row * 1.7) * 0.5 + 0.5;
					const radius = layer.size * depthScale * (0.58 + variation * 0.78 + cluster * 0.36);
					const skip = point.depth < 0.12 && variation < 0.06;

					if (skip) {
						previousPoint = undefined;
						continue;
					}

					if (
						layer.connectEvery &&
						previousPoint &&
						column % layer.connectEvery === 0 &&
						variation > 0.28
					) {
						connectors.moveTo(previousPoint.x, previousPoint.y);
						connectors.lineTo(point.x, point.y);

						if (row > 0 && column % (layer.connectEvery * 2) === 0) {
							const upper = pointFor(layer, row - 1, column, time);
							connectors.moveTo(point.x, point.y);
							connectors.lineTo(upper.x, upper.y);
						}
					}

					const path =
						variation > 0.91 && point.depth > 0.28
							? glowDots[colorBucketFor(point.x, bucketCount)]
							: variation > 0.7
								? brightDots[colorBucketFor(point.x, bucketCount)]
								: variation > 0.34
									? midDots[colorBucketFor(point.x, bucketCount)]
									: dimDots[colorBucketFor(point.x, bucketCount)];

					path.moveTo(point.x + radius, point.y);
					path.arc(point.x, point.y, radius, 0, Math.PI * 2);
					previousPoint = point;
				}
			}

			context.save();
			context.globalCompositeOperation = 'lighter';
			context.strokeStyle = 'rgba(92, 139, 190, 0.13)';
			context.lineWidth = 0.45;
			context.stroke(connectors);

			for (let bucket = 0; bucket < bucketCount; bucket += 1) {
				const x = ((bucket + 0.5) / bucketCount) * width;

				context.fillStyle = colorFor(x, layer.pointAlpha * 0.22);
				context.fill(dimDots[bucket]);
				context.fillStyle = colorFor(x, layer.pointAlpha * 0.4);
				context.fill(midDots[bucket]);
				context.fillStyle = colorFor(x, layer.pointAlpha * 0.62);
				context.fill(brightDots[bucket]);
				context.fillStyle = colorFor(x, layer.pointAlpha * 0.86);
				context.fill(glowDots[bucket]);
			}
			context.restore();
		};

		function draw(now: number) {
			const time = reduce ? 5.4 : (now - start) / 1000;

			if (reduce) {
				pointer.x = 0;
				pointer.y = 0;
			} else {
				pointer.x += (pointer.targetX - pointer.x) * 0.045;
				pointer.y += (pointer.targetY - pointer.y) * 0.045;
			}

			context.clearRect(0, 0, width, height);

			for (const layer of layers) {
				drawLayer(layer, time);
			}
		}

		const tick = (now: number) => {
			if (now - lastFrame >= frameInterval) {
				lastFrame = now;
				draw(now);
			}

			raf = window.requestAnimationFrame(tick);
		};

		const startLoop = () => {
			window.cancelAnimationFrame(raf);

			if (!reduce && isVisible && document.visibilityState === 'visible') {
				lastFrame = 0;
				raf = window.requestAnimationFrame(tick);
			}
		};

		const syncMotion = () => {
			reduce = reducedMotion.matches;
			window.cancelAnimationFrame(raf);

			if (reduce) {
				draw(start + 5400);
				return;
			}

			start = performance.now();
			startLoop();
		};

		const onPointerMove = (event: PointerEvent) => {
			const rect = host.getBoundingClientRect();
			pointer.targetX = ((event.clientX - rect.left) / Math.max(width, 1) - 0.5) * 2;
			pointer.targetY = ((event.clientY - rect.top) / Math.max(height, 1) - 0.5) * 2;
		};

		const observer = new ResizeObserver(resize);
		observer.observe(host);
		const visibilityObserver = new IntersectionObserver(([entry]) => {
			isVisible = Boolean(entry?.isIntersecting);
			startLoop();
		});
		visibilityObserver.observe(host);
		resize();
		syncMotion();

		host.addEventListener('pointermove', onPointerMove, { passive: true });
		host.addEventListener('pointerleave', () => {
			pointer.targetX = 0;
			pointer.targetY = 0;
		});
		document.addEventListener('visibilitychange', startLoop);
		reducedMotion.addEventListener('change', syncMotion);
	});
</script>
