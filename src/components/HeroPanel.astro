---
import TerminalWindow from './TerminalWindow.astro';
import WaveBackground from './WaveBackground.astro';
import asteroidSrc from '../assets/aesteroid.svg?url';

const helpLines = [
	'<span class="dim">available commands:</span>',
	'<span class="cmd">projects</span> - list deployed projects',
	'<span class="cmd">skills</span> - view my tech arsenal',
	'<span class="cmd">experience</span> - quest log (work history)',
	'<span class="cmd">contact</span> - get in touch',
	'<span class="cmd">fun-facts</span> - useless but interesting',
	'<span class="cmd">bugs</span> - known issues (there are some)',
	'<span class="cmd">easter-egg</span> - ???',
	'<span class="cmd">sudo hire-me</span> - instantly get hired*',
	'<span class="cmd">clear</span> - clear the screen',
	'<span class="cmd">exit</span> - leave (why tho?)',
];
---

<section id="home" class="hero-panel" aria-labelledby="hero-title">
	<div class="stars" aria-hidden="true">
		<img class="asteroid one" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid two" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid three" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid four" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid five" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid six" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid seven" src={asteroidSrc} alt="" loading="eager" />
		<span class="star-dot alpha"></span>
		<span class="star-dot beta"></span>
		<span class="star-dot gamma"></span>
		<span class="star-dot delta"></span>
		<span class="star-dot epsilon"></span>
		<span class="star-dot zeta"></span>
		<span class="star-dot eta"></span>
		<span class="star-dot theta"></span>
		<span class="star-dot iota"></span>
		<span class="star-dot kappa"></span>
		<span class="star-dot lambda"></span>
		<span class="star-dot mu"></span>
		<span class="star-dot nu"></span>
		<span class="star-dot xi"></span>
		<span class="star-dot omicron"></span>
		<span class="star-dot pi"></span>
		<span class="star-dot rho"></span>
		<span class="star-dot sigma"></span>
		<span class="star-dot tau"></span>
		<span class="star-dot upsilon"></span>
		<span class="star-dot phi"></span>
		<span class="star-dot chi"></span>
	</div>
	<WaveBackground />

	<div class="hero-copy">
		<p class="mode">// developer mode: on</p>
		<h1 id="hero-title">Arib Farooqui<span>_</span></h1>
		<p class="role">Software Engineer</p>
		<p class="summary">
			I build interactive experiences, developer tools, and things that make computers do cool
			stuff. Sometimes it works. Sometimes it ships.
		</p>
		<div class="actions">
			<a class="primary" href="#projects">&gt; View Projects</a>
			<a class="secondary" href="/resume.pdf">&gt; Download Resume</a>
		</div>
	</div>

	<div class="terminal-wrap">
		<TerminalWindow title="Terminal" lines={helpLines} />
	</div>

	<div class="tooltip" role="status">
		<span aria-hidden="true">[::]</span>
		<p><strong>Tooltip:</strong> Loads too fast to read this message. Suffering from success.</p>
		<button aria-label="Dismiss tooltip">×</button>
	</div>
</section>

<style>
	.hero-panel {
		position: relative;
		display: grid;
		grid-template-columns: minmax(360px, 0.86fr) minmax(390px, 1fr);
		align-items: center;
		gap: clamp(24px, 3.4vw, 58px);
		min-height: 0;
		padding: clamp(30px, 4vw, 62px) clamp(28px, 4vw, 68px) 70px;
		overflow: hidden;
	}

	.hero-panel::before {
		position: absolute;
		inset: 0;
		z-index: 0;
		content: "";
		background:
			radial-gradient(circle at 10% 24%, #d8f4ff 0 1px, transparent 1.5px),
			radial-gradient(circle at 31% 8%, #ffffff 0 1px, transparent 1.5px),
			radial-gradient(circle at 52% 36%, #ffffff 0 1.5px, transparent 2px),
			radial-gradient(circle at 72% 16%, #ffffff 0 1px, transparent 1.5px),
			radial-gradient(circle at 88% 18%, #ffffff 0 1.5px, transparent 2px),
			radial-gradient(circle at 2% 63%, rgba(95, 230, 255, 0.55) 0 1px, transparent 1.5px),
			linear-gradient(180deg, rgba(1, 7, 16, 0.04), rgba(1, 6, 14, 0.58));
	}

	.hero-copy,
	.terminal-wrap,
	.tooltip {
		position: relative;
		z-index: 3;
	}

	.stars {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.stars::before,
	.stars::after {
		position: absolute;
		inset: 0;
		content: "";
		background-repeat: no-repeat;
	}

	.stars::before {
		opacity: 0.74;
		background:
			radial-gradient(circle at 7% 18%, rgba(239, 247, 255, 0.8) 0 1px, transparent 1.5px),
			radial-gradient(circle at 14% 38%, rgba(95, 230, 255, 0.64) 0 1px, transparent 1.5px),
			radial-gradient(circle at 18% 72%, rgba(239, 247, 255, 0.68) 0 1px, transparent 1.5px),
			radial-gradient(circle at 24% 10%, rgba(255, 227, 94, 0.58) 0 1px, transparent 1.5px),
			radial-gradient(circle at 29% 58%, rgba(239, 247, 255, 0.7) 0 1px, transparent 1.5px),
			radial-gradient(circle at 34% 31%, rgba(239, 247, 255, 0.56) 0 1px, transparent 1.5px),
			radial-gradient(circle at 42% 70%, rgba(94, 255, 181, 0.58) 0 1px, transparent 1.5px),
			radial-gradient(circle at 49% 12%, rgba(239, 247, 255, 0.74) 0 1px, transparent 1.5px),
			radial-gradient(circle at 56% 48%, rgba(95, 230, 255, 0.62) 0 1px, transparent 1.5px),
			radial-gradient(circle at 64% 28%, rgba(239, 247, 255, 0.7) 0 1px, transparent 1.5px),
			radial-gradient(circle at 71% 64%, rgba(239, 247, 255, 0.56) 0 1px, transparent 1.5px),
			radial-gradient(circle at 83% 40%, rgba(255, 227, 94, 0.56) 0 1px, transparent 1.5px),
			radial-gradient(circle at 91% 72%, rgba(239, 247, 255, 0.68) 0 1px, transparent 1.5px);
	}

	.stars::after {
		opacity: 0.52;
		background:
			radial-gradient(circle at 4% 82%, rgba(239, 247, 255, 0.64) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 12% 9%, rgba(239, 247, 255, 0.58) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 21% 48%, rgba(239, 247, 255, 0.52) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 27% 84%, rgba(95, 230, 255, 0.52) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 37% 6%, rgba(239, 247, 255, 0.58) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 45% 41%, rgba(239, 247, 255, 0.5) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 53% 86%, rgba(255, 227, 94, 0.46) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 61% 8%, rgba(239, 247, 255, 0.62) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 68% 78%, rgba(95, 230, 255, 0.5) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 77% 22%, rgba(239, 247, 255, 0.58) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 86% 9%, rgba(239, 247, 255, 0.52) 0 0.75px, transparent 1.25px),
			radial-gradient(circle at 95% 54%, rgba(239, 247, 255, 0.6) 0 0.75px, transparent 1.25px);
	}

	.hero-copy {
		max-width: 500px;
		animation: rise 700ms ease both;
	}

	.mode {
		margin: 0 0 20px;
		color: var(--green);
		font-size: clamp(0.66rem, 0.72vw, 0.82rem);
		font-weight: 700;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: #fff;
		font-size: clamp(2.35rem, 3.15vw, 4.1rem);
		line-height: 0.94;
		text-transform: uppercase;
		text-shadow:
			0 0 28px rgba(255, 255, 255, 0.18),
			3px 0 0 rgba(94, 255, 181, 0.08),
			-3px 0 0 rgba(182, 140, 255, 0.08);
	}

	h1 span {
		color: #e5f9ff;
		animation: blink 980ms steps(2, end) infinite;
	}

	.role {
		margin: 18px 0 22px;
		color: var(--purple);
		font-size: clamp(1rem, 1.2vw, 1.35rem);
		font-weight: 800;
		text-transform: uppercase;
	}

	.summary {
		max-width: 500px;
		margin: 0;
		color: #c4d0df;
		font-size: clamp(0.86rem, 0.9vw, 1rem);
		line-height: 1.75;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 32px;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 22px;
		border-radius: 4px;
		font-size: clamp(0.7rem, 0.78vw, 0.86rem);
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background 160ms ease;
	}

	.primary {
		border: 1px solid var(--line-bright);
		background: rgba(94, 255, 181, 0.1);
		color: var(--green);
	}

	.secondary {
		border: 1px solid rgba(255, 255, 255, 0.28);
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}

	.actions a:hover {
		transform: translateY(-2px);
	}

	.terminal-wrap {
		max-width: 560px;
		animation: terminalIn 860ms 120ms ease both;
	}

	.terminal-wrap :global(.terminal-body) {
		padding: 16px 20px;
		font-size: clamp(0.62rem, 0.68vw, 0.78rem);
		line-height: 1.5;
	}

	.asteroid {
		position: absolute;
		display: block;
		height: auto;
		filter:
			drop-shadow(0 0 10px rgba(95, 230, 255, 0.14))
			drop-shadow(0 10px 14px rgba(0, 0, 0, 0.22));
		image-rendering: pixelated;
		opacity: 0.68;
		transform-origin: center;
		will-change: transform;
	}

	.one {
		--base-rotate: -18deg;
		--scale: 1;
		top: 6%;
		left: 40%;
		width: 96px;
		animation: asteroidDriftOne 28s ease-in-out infinite;
	}

	.two {
		--base-rotate: 31deg;
		--scale: 0.52;
		top: 21%;
		left: 16%;
		width: 86px;
		opacity: 0.56;
		animation: asteroidDriftTwo 34s ease-in-out -8s infinite;
	}

	.three {
		--base-rotate: 118deg;
		--scale: 0.34;
		top: 8%;
		left: 9%;
		width: 78px;
		opacity: 0.44;
		animation: asteroidDriftThree 31s ease-in-out -14s infinite;
	}

	.four {
		--base-rotate: -64deg;
		--scale: 0.7;
		right: -2%;
		top: 34%;
		width: 92px;
		opacity: 0.48;
		animation: asteroidDriftFour 37s ease-in-out -18s infinite;
	}

	.five {
		--base-rotate: 206deg;
		--scale: 0.42;
		right: 7%;
		bottom: 22%;
		width: 80px;
		opacity: 0.38;
		animation: asteroidDriftFive 42s ease-in-out -12s infinite;
	}

	.six {
		--base-rotate: 77deg;
		--scale: 0.46;
		top: 16%;
		right: 27%;
		width: 82px;
		opacity: 0.36;
		animation: asteroidDriftSix 39s ease-in-out -20s infinite;
	}

	.seven {
		--base-rotate: -132deg;
		--scale: 0.32;
		bottom: 16%;
		left: 32%;
		width: 74px;
		opacity: 0.32;
		animation: asteroidDriftSeven 45s ease-in-out -26s infinite;
	}

	.star-dot {
		--star-alpha: 0.72;
		--star-color: rgba(239, 247, 255, 0.84);
		--star-glow: 10px;
		--star-size: 3px;
		position: absolute;
		display: block;
		width: var(--star-size);
		aspect-ratio: 1;
		border-radius: 50%;
		background: currentColor;
		box-shadow: 0 0 var(--star-glow) currentColor;
		color: var(--star-color);
		opacity: var(--star-alpha);
	}

	.alpha {
		--star-alpha: 0.92;
		--star-size: 2px;
		top: 14%;
		left: 30%;
	}

	.beta {
		--star-alpha: 0.68;
		--star-color: rgba(94, 255, 181, 0.82);
		--star-glow: 8px;
		--star-size: 3px;
		top: 30%;
		left: 58%;
	}

	.gamma {
		--star-alpha: 0.75;
		--star-size: 2px;
		top: 13%;
		right: 19%;
	}

	.delta {
		--star-alpha: 0.58;
		--star-color: rgba(255, 227, 94, 0.78);
		--star-size: 2px;
		top: 45%;
		left: 5%;
	}

	.epsilon {
		--star-alpha: 0.62;
		--star-size: 3px;
		right: 8%;
		bottom: 28%;
	}

	.zeta {
		--star-alpha: 0.8;
		--star-size: 2px;
		top: 21%;
		right: 12%;
	}

	.eta {
		--star-alpha: 0.9;
		--star-size: 2px;
		top: 38%;
		left: 52%;
	}

	.theta {
		--star-alpha: 0.42;
		--star-color: rgba(95, 230, 255, 0.8);
		--star-size: 2px;
		bottom: 34%;
		left: 2%;
	}

	.iota {
		--star-alpha: 0.36;
		--star-glow: 6px;
		--star-size: 1px;
		top: 18%;
		left: 63%;
	}

	.kappa {
		--star-alpha: 0.5;
		--star-size: 2px;
		top: 26%;
		right: 33%;
	}

	.lambda {
		--star-alpha: 0.46;
		--star-color: rgba(95, 230, 255, 0.78);
		--star-size: 1px;
		left: 45%;
		bottom: 23%;
	}

	.mu {
		--star-alpha: 0.66;
		--star-size: 2px;
		right: 18%;
		bottom: 12%;
	}

	.nu {
		--star-alpha: 0.34;
		--star-glow: 5px;
		--star-size: 1px;
		top: 10%;
		right: 41%;
	}

	.xi {
		--star-alpha: 0.76;
		--star-size: 2px;
		top: 27%;
		left: 3%;
	}

	.omicron {
		--star-alpha: 0.4;
		--star-color: rgba(255, 227, 94, 0.72);
		--star-size: 1px;
		top: 52%;
		right: 9%;
	}

	.pi {
		--star-alpha: 0.88;
		--star-size: 2px;
		top: 22%;
		left: 36%;
	}

	.rho {
		--star-alpha: 0.44;
		--star-glow: 5px;
		--star-size: 1px;
		top: 17%;
		left: 74%;
	}

	.sigma {
		--star-alpha: 0.58;
		--star-size: 2px;
		top: 41%;
		right: 24%;
	}

	.tau {
		--star-alpha: 0.32;
		--star-color: rgba(95, 230, 255, 0.76);
		--star-glow: 5px;
		--star-size: 1px;
		left: 38%;
		bottom: 17%;
	}

	.upsilon {
		--star-alpha: 0.7;
		--star-size: 2px;
		right: 5%;
		bottom: 42%;
	}

	.phi {
		--star-alpha: 0.38;
		--star-glow: 5px;
		--star-size: 1px;
		top: 34%;
		right: 15%;
	}

	.chi {
		--star-alpha: 0.52;
		--star-color: rgba(239, 247, 255, 0.78);
		--star-size: 2px;
		left: 48%;
		bottom: 9%;
	}

	.tooltip {
		position: absolute;
		right: clamp(28px, 4vw, 70px);
		bottom: 16px;
		display: grid;
		grid-template-columns: 32px 1fr 24px;
		align-items: center;
		gap: 12px;
		width: min(560px, calc(100% - 56px));
		padding: 11px 14px;
		border: 1px solid rgba(148, 183, 220, 0.32);
		border-radius: 5px;
		background: rgba(7, 14, 27, 0.92);
		color: #cbd6e4;
		font-size: clamp(0.58rem, 0.66vw, 0.75rem);
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
		animation: rise 760ms 350ms ease both;
	}

	.tooltip span {
		color: var(--green);
		font-size: 1rem;
		text-align: center;
	}

	.tooltip p {
		margin: 0;
	}

	.tooltip strong {
		color: var(--text);
		text-transform: uppercase;
	}

	.tooltip button {
		width: 24px;
		aspect-ratio: 1;
		border: 0;
		color: var(--text);
		background: transparent;
		cursor: pointer;
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes terminalIn {
		from {
			opacity: 0;
			transform: translateX(20px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateX(0) scale(1);
		}
	}

	@keyframes asteroidDriftOne {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(24px, -16px, 0) rotate(calc(var(--base-rotate) + 10deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftTwo {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(-18px, 18px, 0) rotate(calc(var(--base-rotate) - 14deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftThree {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(20px, 14px, 0) rotate(calc(var(--base-rotate) + 18deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftFour {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(-28px, -10px, 0) rotate(calc(var(--base-rotate) - 9deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftFive {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(18px, 12px, 0) rotate(calc(var(--base-rotate) + 12deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftSix {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(-16px, -18px, 0) rotate(calc(var(--base-rotate) - 11deg))
				scale(var(--scale));
		}
	}

	@keyframes asteroidDriftSeven {
		0%,
		100% {
			transform: translate3d(0, 0, 0) rotate(var(--base-rotate)) scale(var(--scale));
		}

		50% {
			transform: translate3d(14px, -12px, 0) rotate(calc(var(--base-rotate) + 9deg))
				scale(var(--scale));
		}
	}

	@keyframes blink {
		50% {
			opacity: 0;
		}
	}

	@media (max-width: 1180px) {
		.hero-panel {
			min-height: 560px;
		}
	}

	@media (max-width: 850px) {
		.hero-panel {
			grid-template-columns: 1fr;
			align-content: center;
			min-height: auto;
			padding-bottom: 82px;
		}

		.terminal-wrap {
			max-width: 620px;
		}
	}

	@media (max-width: 560px) {
		.hero-panel {
			padding: 32px 18px 92px;
		}

		.one {
			--scale: 0.46;
			top: 4%;
			left: 70%;
			width: 86px;
			opacity: 0.45;
		}

		.two,
		.three,
		.four,
		.five,
		.six,
		.seven,
		.beta,
		.delta,
		.eta,
		.lambda,
		.xi {
			display: none;
		}

		.actions a {
			width: 100%;
		}

		.tooltip {
			right: 14px;
			left: 14px;
			width: auto;
			grid-template-columns: 28px 1fr 24px;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hero-copy,
		.terminal-wrap,
		.asteroid,
		h1 span,
		.tooltip {
			animation: none;
		}

		.asteroid {
			transform: rotate(var(--base-rotate)) scale(var(--scale));
		}
	}
</style>
