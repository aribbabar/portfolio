	.star-dot {
		--star-alpha: 0.72;
		--star-color: rgba(239, 247, 255, 0.84);
		--star-glow: 10px;
		--star-size: 3px;
		position: absolute;
		display: block;
		width: var(--star-size);
		aspect-ratio: 1;
		border-radius: 50%;
		background: currentColor;
		box-shadow: 0 0 var(--star-glow) currentColor;
		color: var(--star-color);
		opacity: var(--star-alpha);
	}

	.alpha {
