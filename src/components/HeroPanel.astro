---
import PixelIcon from './PixelIcon.astro';
import TerminalWindow from './TerminalWindow.astro';
import WaveBackground from './WaveBackground.astro';
import asteroidSrc from '../assets/aesteroid.svg?url';

const closeIcon = '/pixelarticons/close.svg';
const infoIcon = '/pixelarticons/info-box.svg';

const helpLines = [
	'<span class="dim">available commands:</span>',
	'<span class="cmd">help</span> - show available commands',
	'<span class="cmd">ls [folder]</span> - list files and folders',
	'<span class="cmd">cd &lt;folder&gt;</span> - change directory',
	'<span class="cmd">pwd</span> - print current directory',
	'<span class="cmd">cat &lt;file&gt;</span> - read a file',
	'<span class="cmd">tree</span> - show the tiny filesystem',
	'<span class="cmd">echo &lt;text&gt;</span> - print text back',
	'<span class="cmd">grep &lt;text&gt; &lt;file&gt;</span> - search a readable file',
	'<span class="cmd">contact</span> - get in touch',
	'<span class="cmd">sudo hire-me</span> - run the important command',
	'<span class="cmd">mkdir / touch / rm</span> - try static-site file ops',
	'<span class="cmd">easter-egg</span> - ???',
	'<span class="cmd">clear</span> - clear this terminal',
];
---

<section id="home" class="hero-panel" aria-labelledby="hero-title">
	<div class="stars" aria-hidden="true">
		<img class="asteroid one" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid two" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid three" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid four" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid five" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid six" src={asteroidSrc} alt="" loading="eager" />
		<img class="asteroid seven" src={asteroidSrc} alt="" loading="eager" />
		<span class="star-dot alpha"></span>
		<span class="star-dot beta"></span>
		<span class="star-dot gamma"></span>
		<span class="star-dot delta"></span>
		<span class="star-dot epsilon"></span>
		<span class="star-dot zeta"></span>
		<span class="star-dot eta"></span>
		<span class="star-dot theta"></span>
		<span class="star-dot iota"></span>
		<span class="star-dot kappa"></span>
		<span class="star-dot lambda"></span>
		<span class="star-dot mu"></span>
		<span class="star-dot nu"></span>
		<span class="star-dot xi"></span>
		<span class="star-dot omicron"></span>
		<span class="star-dot pi"></span>
		<span class="star-dot rho"></span>
		<span class="star-dot sigma"></span>
		<span class="star-dot tau"></span>
		<span class="star-dot upsilon"></span>
		<span class="star-dot phi"></span>
		<span class="star-dot chi"></span>
		<span class="star-dot psi"></span>
		<span class="star-dot omega"></span>
		<span class="star-dot nova"></span>
		<span class="star-dot quasar"></span>
		<span class="star-dot pulsar"></span>
		<span class="star-dot vega"></span>
		<span class="star-dot rigel"></span>
		<span class="star-dot sirius"></span>
		<span class="star-dot orion"></span>
		<span class="star-dot lyra"></span>
		<span class="star-dot cygnus"></span>
		<span class="star-dot deneb"></span>
		<span class="star-dot atlas"></span>
		<span class="star-dot mira"></span>
		<span class="star-dot sol"></span>
		<span class="star-dot polaris"></span>
		<span class="star-dot altair"></span>
		<span class="star-dot castor"></span>
		<span class="star-dot pollux"></span>
		<span class="star-dot capella"></span>
		<span class="star-dot arcturus"></span>
		<span class="star-dot betelgeuse"></span>
		<span class="star-dot bellatrix"></span>
		<span class="star-dot antares"></span>
		<span class="star-dot achernar"></span>
		<span class="star-dot alnair"></span>
		<span class="star-dot hadar"></span>
		<span class="star-dot acrux"></span>
		<span class="star-dot spica"></span>
		<span class="star-dot procyon"></span>
	</div>
	<WaveBackground />

	<div class="hero-copy">
		<p class="mode">// developer mode: on</p>
		<h1 id="hero-title">Arib Farooqui<span>_</span></h1>
		<p class="role">Software Engineer</p>
		<p class="summary">
			I build interactive experiences, developer tools, and things that make computers do cool
			stuff. Sometimes it works. Sometimes it ships.
		</p>
		<div class="actions">
			<a class="primary" href="#projects">&gt; View Projects</a>
			<a class="secondary" href="/resume.pdf">&gt; Download Resume</a>
		</div>
	</div>

	<div class="terminal-wrap">
		<TerminalWindow title="Terminal" lines={helpLines} />
	</div>

	<div class="tooltip" role="status" data-hero-tooltip>
		<PixelIcon src={infoIcon} class="tooltip-icon" />
		<p><strong>Tooltip:</strong> <span data-hero-tooltip-message>Loading a questionable tip...</span></p>
		<button type="button" aria-label="Dismiss tooltip" data-hero-tooltip-dismiss>
			<PixelIcon src={closeIcon} />
		</button>
	</div>
</section>

<style>
	.hero-panel {
		position: relative;
		display: grid;
		grid-template-columns: minmax(360px, 0.86fr) minmax(390px, 1fr);
		align-items: center;
		gap: clamp(24px, 3.4vw, 58px);
		min-height: 0;
		padding: clamp(30px, 4vw, 62px) clamp(28px, 4vw, 68px) 70px;
		overflow: hidden;
	}

	.hero-panel::before {
		position: absolute;
		inset: 0;
		z-index: 0;
		content: "";
		background:
			radial-gradient(circle at 10% 24%, #d8f4ff 0 1px, transparent 1.5px),
			radial-gradient(circle at 31% 8%, #ffffff 0 1px, transparent 1.5px),
			radial-gradient(circle at 52% 36%, #ffffff 0 1.5px, transparent 2px),
			radial-gradient(circle at 72% 16%, #ffffff 0 1px, transparent 1.5px),
			radial-gradient(circle at 88% 18%, #ffffff 0 1.5px, transparent 2px),
			radial-gradient(circle at 2% 63%, rgba(95, 230, 255, 0.55) 0 1px, transparent 1.5px),
			linear-gradient(180deg, rgba(1, 7, 16, 0.04), rgba(1, 6, 14, 0.58));
	}

	.hero-copy,
	.terminal-wrap,
	.tooltip {
		position: relative;
		z-index: 3;
	}

	.stars {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
	}

	.hero-copy {
		max-width: 500px;
		animation: rise 700ms ease both;
	}

	.mode {
		margin: 0 0 20px;
		color: var(--green);
		font-size: clamp(0.66rem, 0.72vw, 0.82rem);
		font-weight: 700;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		color: #fff;
		font-size: clamp(2.35rem, 3.15vw, 4.1rem);
		line-height: 0.94;
		text-transform: uppercase;
		text-shadow:
			0 0 28px rgba(255, 255, 255, 0.18),
			3px 0 0 rgba(94, 255, 181, 0.08),
			-3px 0 0 rgba(182, 140, 255, 0.08);
	}

	h1 span {
		color: #e5f9ff;
		animation: cursorPulse 620ms ease-in-out infinite alternate;
	}

	.role {
		margin: 18px 0 22px;
		color: var(--purple);
		font-size: clamp(1rem, 1.2vw, 1.35rem);
		font-weight: 800;
		text-transform: uppercase;
	}

	.summary {
		max-width: 500px;
		margin: 0;
		color: #c4d0df;
		font-size: clamp(0.86rem, 0.9vw, 1rem);
		line-height: 1.75;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 32px;
	}

	.actions a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 42px;
		padding: 0 22px;
		border-radius: 4px;
		font-size: clamp(0.7rem, 0.78vw, 0.86rem);
		font-weight: 800;
		text-decoration: none;
		text-transform: uppercase;
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background 160ms ease;
	}

	.primary {
		border: 1px solid var(--line-bright);
		background: rgba(94, 255, 181, 0.1);
		color: var(--green);
	}

	.secondary {
		border: 1px solid rgba(255, 255, 255, 0.28);
		color: var(--text);
		background: rgba(255, 255, 255, 0.04);
	}

	.actions a:hover {
		transform: translateY(-2px);
	}

	.terminal-wrap {
		max-width: 560px;
		animation: terminalIn 860ms 120ms ease both;
	}

	.terminal-wrap :global(.terminal-body) {
		padding: 16px 20px;
		font-size: clamp(0.62rem, 0.68vw, 0.78rem);
		line-height: 1.5;
	}

	.asteroid {
		position: absolute;
		display: block;
		height: auto;
		filter:
			drop-shadow(0 0 10px rgba(95, 230, 255, 0.14))
			drop-shadow(0 10px 14px rgba(0, 0, 0, 0.22));
		image-rendering: pixelated;
		opacity: 0.68;
		transform-origin: center;
		will-change: transform;
	}

	.one {
		--base-rotate: -18deg;
		--scale: 1;
		top: 6%;
		left: 40%;
		width: 96px;
		animation: asteroidDriftOne 28s ease-in-out infinite;
	}

	.two {
		--base-rotate: 31deg;
		--scale: 0.52;
		top: 21%;
		left: 16%;
		width: 86px;
