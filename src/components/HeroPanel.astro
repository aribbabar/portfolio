	.tooltip {
		position: absolute;
		right: clamp(28px, 4vw, 70px);
		bottom: 16px;
		display: grid;
		grid-template-columns: 32px 1fr 24px;
		align-items: center;
		gap: 12px;
		width: min(560px, calc(100% - 56px));
		padding: 11px 14px;
		border: 1px solid rgba(148, 183, 220, 0.32);
		border-radius: 5px;
		background: rgba(7, 14, 27, 0.92);
		color: #cbd6e4;
		font-size: clamp(0.58rem, 0.66vw, 0.75rem);
		box-shadow: 0 18px 50px rgba(0, 0, 0, 0.28);
		animation: rise 760ms 350ms ease both;
	}

	.tooltip :global(.tooltip-icon) {
		--pixel-icon-size: 24px;
		color: var(--green);
		justify-self: center;
	}

	.tooltip p {
		margin: 0;
		line-height: 1.45;
		overflow-wrap: anywhere;
	}

	.tooltip strong {
		color: var(--text);
		text-transform: uppercase;
	}

	.tooltip button {
		display: grid;
		place-items: center;
		width: 24px;
		aspect-ratio: 1;
		border: 0;
		color: var(--text);
		background: transparent;
	}

	.tooltip button :global(.pixel-icon) {
		--pixel-icon-size: 18px;
	}

	@keyframes rise {
		from {
			opacity: 0;
			transform: translateY(16px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

