<script>
	const tooltipMessages = [
		'Dominating in League of Legends boils down to three fundamentals: last-hit for gold, master a small champion pool, and mute chat before tilt gets a vote.',
		'Life tip: if the task takes two minutes, do it now. If it takes three weeks, rename it to phase two.',
		'Life tip: drink water before debugging. Half of all production incidents are just dehydration wearing a hoodie.',
		'Coding tip: write the error message you wish you had before future-you becomes the target audience.',
		'Coding tip: if a function needs a paragraph to explain its boolean flag, the boolean flag is probably two functions in a trench coat.',
		'Commit messages are tiny postcards from the crime scene. Make them useful.',
		'The fastest code is the code you deleted, unless it was the billing check. Put that back.',
		'Somewhere, a loading spinner believes in you.',
		'Warning: this portfolio may contain traces of caffeine, pixels, and suspiciously confident CSS.',
		'Random quote: the moon is just the sun running dark mode.',
	];

	const pickTooltipMessage = () => {
		if (tooltipMessages.length === 1) {
			return tooltipMessages[0];
		}

		const fallbackIndex = Math.floor(Math.random() * tooltipMessages.length);

		try {
			const previousIndex = Number.parseInt(localStorage.getItem('heroTooltipIndex') ?? '', 10);
			const availableIndexes = tooltipMessages
				.map((_, index) => index)
				.filter((index) => index !== previousIndex);
			const nextIndex = availableIndexes[Math.floor(Math.random() * availableIndexes.length)];

			localStorage.setItem('heroTooltipIndex', String(nextIndex));

			return tooltipMessages[nextIndex];
		} catch {
			return tooltipMessages[fallbackIndex];
		}
	};

	document.querySelector('[data-hero-tooltip-message]')?.replaceChildren(pickTooltipMessage());

	document.addEventListener('click', ({ target }) => {
		if (!(target instanceof Element)) {
			return;
		}

		const button = target.closest('[data-hero-tooltip-dismiss]');

		if (!button) {
			return;
		}

		button.closest('[data-hero-tooltip]')?.remove();
	});
</script>
