---
interface Props {
	title: string;
	eyebrow?: string;
	class?: string;
	id?: string;
}

const { title, eyebrow, class: className = '', id } = Astro.props;
---

<section id={id} class:list={['panel', className]}>
	<header class="panel-header">
		<p>&gt; {eyebrow}</p>
		<h2>{title}</h2>
		<slot name="intro" />
	</header>
	<slot />
</section>

<style>
	.panel {
		position: relative;
		min-width: 0;
		padding: clamp(22px, 2.2vw, 42px);
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(180deg, rgba(8, 16, 29, 0.93), rgba(4, 10, 19, 0.94)),
			radial-gradient(circle at 100% 100%, rgba(75, 113, 173, 0.16), transparent 20rem);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.02),
			0 24px 70px rgba(0, 0, 0, 0.28);
		overflow: hidden;
	}

	.panel::after {
		position: absolute;
		inset: 0;
		pointer-events: none;
		content: "";
		background:
			linear-gradient(120deg, rgba(255, 255, 255, 0.045), transparent 22rem),
			repeating-linear-gradient(0deg, transparent, transparent 21px, rgba(255, 255, 255, 0.018) 22px);
		opacity: 0.5;
	}

	.panel-header {
		position: relative;
		z-index: 1;
		margin-bottom: clamp(22px, 2vw, 34px);
	}

	p {
		margin: 0 0 22px;
		color: var(--green);
		font-size: clamp(0.64rem, 0.7vw, 0.78rem);
		font-weight: 700;
		text-transform: uppercase;
	}

	h2 {
		margin: 0;
		color: var(--text);
		font-size: clamp(1.42rem, 1.65vw, 2rem);
		line-height: 1;
		text-transform: uppercase;
		text-shadow: 0 0 22px rgba(255, 255, 255, 0.16);
	}

	:global(.panel [slot='intro']),
	:global(.panel .intro) {
		margin-top: 12px;
		color: var(--muted);
		font-size: clamp(0.68rem, 0.72vw, 0.82rem);
	}

	@media (max-width: 680px) {
		.panel {
			padding: 22px 18px;
		}
	}
</style>
