---
import TerminalWindow from './TerminalWindow.astro';

const hireLines = [
	'Checking qualifications...',
	'Overqualified.',
	'Checking attitude...',
	"Slightly sarcastic. I'll allow it.",
	'Checking vibe...',
	'<span class="ok-text">[ok]</span> Vibe check passed.',
	'Interactive session ready.',
	'<span class="dim">Type help, ls, cd projects, cat contact/github.url, or easter-egg.</span>',
];
---

<section id="contact" class="hire-panel" aria-label="Contact panel">
	<TerminalWindow title="Easter_Egg.exe" command="sudo hire-me" lines={hireLines} wide interactive />
</section>

<style>
	.hire-panel {
		position: relative;
		grid-column: 1 / -1;
		min-width: 0;
		padding: 14px;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(180deg, rgba(8, 16, 29, 0.93), rgba(4, 10, 19, 0.94)),
			radial-gradient(circle at 90% 100%, rgba(182, 140, 255, 0.1), transparent 18rem);
		overflow: hidden;
	}

	.hire-panel :global(.terminal) {
		min-height: 100%;
	}

	.hire-panel :global(.terminal-body) {
		height: 400px;
	}

	@media (max-width: 1180px) {
		.hire-panel {
			grid-column: auto;
			grid-row: auto;
		}
	}

	@media (max-width: 640px) {
		.hire-panel :global(.terminal-body) {
			height: 460px;
		}
	}
</style>
