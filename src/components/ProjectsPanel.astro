---
import Panel from './Panel.astro';

const projects = [
	{
		id: '01',
		state: 'In Development',
		stateClass: 'warning',
		title: 'Draw Rush',
		description: 'Pictionary-style multiplayer game with real-time drawing and guessing chaos.',
		icon: 'palette',
		tags: ['Next.js', 'TypeScript', 'Socket.io', 'Tailwind'],
		status: 'Building',
		action: 'Playtest',
	},
	{
		id: '02',
		state: 'Open Source',
		stateClass: 'open',
		title: 'Docs MCP',
		description: 'Embedding-based MCP server for LLMs to search and understand documentation.',
		icon: 'brain',
		tags: ['Python', 'FastAPI', 'ChromaDB', 'Docker'],
		status: 'Active',
		action: 'Code',
	},
	{
		id: '03',
		state: 'Production',
		stateClass: 'live',
		title: 'LocalKit',
		description: 'Collection of privacy-first browser utilities for everyday use.',
		icon: 'window',
		tags: ['Next.js', 'TypeScript', 'Supabase', 'Tailwind'],
		status: 'Live',
		action: 'Visit',
	},
	{
		id: '04',
		state: 'Secret',
		stateClass: 'secret',
		title: '?????',
		description: 'Something cool is cooking. Check back later or stalk my GitHub.',
		icon: 'lock',
		tags: ['Top Secret'],
		status: 'Locked',
		action: 'Unknown',
	},
];
---

<Panel title="Projects" eyebrow="Mission.Select" class="projects-panel" id="projects">
	<p slot="intro" class="intro">A few missions I have worked on. More to come.</p>
	<div class="project-grid">
		{
			projects.map((project) => (
				<article class="project-card">
					<div class="card-top">
						<span>[{project.id}]</span>
						<span class:list={['badge', project.stateClass]}>{project.state}</span>
					</div>
					<div class:list={['project-icon', project.icon]} aria-hidden="true">
						<span></span>
					</div>
					<h3>{project.title} <span>...</span></h3>
					<p>{project.description}</p>
					<div class="tags">
						{project.tags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
					<footer>
						<span>Status: <strong>{project.status}</strong></span>
						<span>{project.action}</span>
					</footer>
				</article>
			))
		}
	</div>

	<div class="system-row">
		<article class="feed">
			<strong>&gt; System.Feed</strong>
			<p>[10:42:11] Commit pushed: "fixed a bug"</p>
			<p>[10:42:13] New bug introduced. Nature is healing.</p>
			<p>[10:42:17] Coffee level: 73%</p>
		</article>
		<article class="bugs">
			<span>Bugs Squashed</span>
			<strong>287</strong>
			<i aria-hidden="true">[x]</i>
		</article>
	</div>
</Panel>

<style>
	.projects-panel {
		grid-column: 1 / -1;
	}

	.project-grid,
	.system-row {
		position: relative;
		z-index: 1;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: clamp(14px, 1.4vw, 22px);
	}

	.project-card {
		display: grid;
		grid-template-rows: auto 88px auto 1fr auto auto;
		min-height: 325px;
		border: 1px solid rgba(148, 183, 220, 0.28);
		border-radius: 6px;
		background:
			linear-gradient(180deg, rgba(9, 18, 31, 0.9), rgba(5, 11, 20, 0.96)),
			radial-gradient(circle at 70% 16%, rgba(95, 230, 255, 0.08), transparent 10rem);
		overflow: hidden;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.project-card:hover {
		transform: translateY(-4px);
		border-color: rgba(94, 255, 181, 0.56);
		box-shadow: 0 24px 55px rgba(0, 0, 0, 0.32);
	}

	.card-top,
	.project-card footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.card-top {
		padding: 14px 16px 0;
		color: var(--yellow);
		font-size: clamp(0.62rem, 0.66vw, 0.74rem);
		font-weight: 800;
		text-transform: uppercase;
	}

	.badge {
		padding: 4px 7px;
		border: 1px solid currentColor;
		border-radius: 3px;
		color: var(--green);
		background: rgba(94, 255, 181, 0.08);
	}

	.badge.warning {
		color: var(--yellow);
		background: rgba(255, 227, 94, 0.08);
	}

	.badge.live {
		color: var(--green);
	}

	.badge.secret {
		color: var(--purple);
		background: rgba(182, 140, 255, 0.1);
	}

	.project-icon {
		position: relative;
		display: grid;
		place-items: center;
		color: var(--cyan);
		font-size: 3.2rem;
	}

	.project-icon span {
		position: relative;
		display: block;
		width: 64px;
		aspect-ratio: 1;
	}

	.palette span {
		border: 6px solid #f4b664;
		border-right-color: transparent;
		border-radius: 50%;
		box-shadow:
			18px 4px 0 -10px #ff6f8f,
			4px 20px 0 -10px #76f0d4,
			24px 22px 0 -10px #b68cff;
	}

	.palette span::after {
		position: absolute;
		right: -34px;
		bottom: -18px;
		width: 8px;
		height: 74px;
		content: "";
		background: linear-gradient(#bff8ff, #4be9ff);
		transform: rotate(35deg);
		box-shadow: 0 0 12px rgba(95, 230, 255, 0.45);
	}

	.brain span {
		border: 5px solid var(--cyan);
		border-right: 0;
		border-radius: 40px 0 0 40px;
		box-shadow:
			18px 4px 0 -10px var(--purple),
			31px 15px 0 -10px var(--purple),
			26px 33px 0 -10px var(--purple);
	}

	.brain span::after {
		position: absolute;
		right: -24px;
		top: 8px;
		width: 34px;
		height: 44px;
		content: "";
		border-top: 4px solid var(--purple);
		border-right: 4px solid var(--purple);
		border-bottom: 4px solid var(--purple);
	}

	.window span {
		width: 72px;
		height: 54px;
		border: 4px solid var(--purple);
		box-shadow: inset 0 12px 0 rgba(182, 140, 255, 0.22);
	}

	.window span::after {
		position: absolute;
		left: 18px;
		top: 25px;
		content: ">_";
		color: var(--text);
		font-size: 1.1rem;
	}

	.lock span {
		width: 48px;
		height: 42px;
		border: 5px solid #ccd5e2;
		border-radius: 3px;
	}

	.lock span::before {
		position: absolute;
		left: 9px;
		top: -29px;
		width: 28px;
		height: 28px;
		content: "";
		border: 5px solid #ccd5e2;
		border-bottom: 0;
		border-radius: 18px 18px 0 0;
	}

	h3 {
		margin: 0;
		padding: 0 18px;
		color: #fff;
		font-size: clamp(0.95rem, 1vw, 1.25rem);
		line-height: 1.2;
		text-transform: uppercase;
	}

	h3 span {
		color: var(--green);
	}

	.project-card p {
		margin: 14px 0 0;
		padding: 0 18px;
		color: #c7d4e2;
		font-size: clamp(0.68rem, 0.74vw, 0.84rem);
		line-height: 1.58;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		padding: 18px;
	}

	.tags span {
		padding: 4px 6px;
		border: 1px solid rgba(148, 183, 220, 0.28);
		border-radius: 3px;
		color: #cdd8e6;
		background: rgba(255, 255, 255, 0.035);
		font-size: clamp(0.56rem, 0.62vw, 0.68rem);
	}

	.project-card footer {
		padding: 13px 18px;
		border-top: 1px solid rgba(148, 183, 220, 0.18);
		color: var(--muted);
		font-size: clamp(0.6rem, 0.66vw, 0.74rem);
		text-transform: uppercase;
	}

	.project-card footer strong {
		color: var(--green);
	}

	.system-row {
		display: grid;
		grid-template-columns: 1fr minmax(180px, 300px);
		gap: 14px;
		margin-top: 22px;
	}

	.feed,
	.bugs {
		border: 1px solid rgba(148, 183, 220, 0.24);
		border-radius: 5px;
		background: rgba(5, 12, 22, 0.76);
	}

	.feed {
		padding: 14px 18px;
		font-size: clamp(0.62rem, 0.68vw, 0.76rem);
	}

	.feed strong {
		display: block;
		margin-bottom: 8px;
		color: var(--green);
		text-transform: uppercase;
	}

	.feed p {
		margin: 0;
		color: #b8c8d8;
		line-height: 1.45;
	}

	.bugs {
		position: relative;
		display: grid;
		align-content: center;
		padding: 18px 22px;
		min-height: 80px;
	}

	.bugs span {
		color: var(--muted);
		font-size: 0.68rem;
		text-transform: uppercase;
	}

	.bugs strong {
		margin-top: 6px;
		color: var(--text);
		font-size: 1.45rem;
		font-weight: 500;
	}

	.bugs i {
		position: absolute;
		right: 28px;
		bottom: 22px;
		color: #e0e7f3;
		font-style: normal;
	}

	@media (max-width: 1420px) {
		.project-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 1180px) {
		.projects-panel {
			grid-column: auto;
		}
	}

	@media (max-width: 660px) {
		.project-grid,
		.system-row {
			grid-template-columns: 1fr;
		}
	}
</style>
