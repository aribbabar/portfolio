---
import Panel from './Panel.astro';
import PixelIcon from './PixelIcon.astro';
import alienIcon from '../assets/alien.svg?url';
import lockIcon from '../assets/lock.svg?url';
import brainIcon from '../assets/neon-brain.svg?url';
import paletteIcon from '../assets/palette-and-brush.svg?url';
import terminalIcon from '../assets/terminal.svg?url';

const externalLinkIcon = '/pixelarticons/external-link.svg';

const projects = [
	{
		id: '01',
		state: 'In Development',
		stateClass: 'warning',
		title: 'Draw Rush',
		description: 'Pictionary-style multiplayer game with real-time drawing and guessing chaos.',
		icon: paletteIcon,
		tags: ['React', 'Cloudflare', 'R2', 'Durable Objects'],
		status: 'Building',
		links: [],
	},
	{
		id: '02',
		state: 'Open Source',
		stateClass: 'open',
		title: 'LocalKit Docs',
		description: 'Embedding-based MCP server for LLMs to search and understand documentation.',
		icon: brainIcon,
		tags: ['Python', 'FastAPI', 'ChromaDB', 'Docker'],
		status: 'Active',
		links: [
			{
				label: 'GitHub',
				href: 'https://github.com/aribbabar/localkit-docs',
			},
		],
	},
	{
		id: '03',
		state: 'Open Source',
		stateClass: 'open',
		title: 'LocalKit',
		description: 'Collection of privacy-first browser utilities for everyday use.',
		icon: terminalIcon,
		tags: ['TypeScript', 'Tailwind'],
		status: 'Active',
		links: [
			{
				label: 'GitHub',
				href: 'https://github.com/aribbabar/localkit.dev',
			},
			{
				label: 'Website',
				href: 'https://localkit.dev',
			},
		],
	},
	{
		id: '04',
		state: 'Secret',
		stateClass: 'secret',
		title: '?????',
		description: 'Something cool is cooking. Check back later or stalk my GitHub.',
		icon: lockIcon,
		tags: ['Top Secret'],
		status: 'Locked',
		links: [],
	},
];
---

<Panel title="Projects" eyebrow="Mission.Select" class="projects-panel" id="projects">
	<p slot="intro" class="intro">A few missions I have worked on. More to come.</p>
	<div class="project-grid">
		{
			projects.map((project) => (
				<article class="project-card">
					<div class="card-top">
						<span>[{project.id}]</span>
						<span class:list={['badge', project.stateClass]}>{project.state}</span>
					</div>
					<div class="project-icon" aria-hidden="true">
						<img
							src={project.icon}
							alt=""
							width="86"
							height="82"
							loading="lazy"
							decoding="async"
						/>
					</div>
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					<div class="tags">
						{project.tags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
					<footer>
						<span>Status: <strong>{project.status}</strong></span>
						{
							project.links.length > 0 && (
								<div class="project-links" aria-label={`${project.title} links`}>
									{project.links.map((link) => (
										<a href={link.href} target="_blank" rel="noreferrer">
											{link.label}
											<PixelIcon src={externalLinkIcon} />
										</a>
									))}
								</div>
							)
						}
					</footer>
				</article>
			))
		}
	</div>

	<div class="system-row">
		<article class="feed">
			<strong>&gt; System.Feed</strong>
			<p>[10:42:11] Commit pushed: "fixed a bug"</p>
			<p>[10:42:13] New bug introduced. Nature is healing.</p>
			<p>[10:42:17] Coffee level: 73%</p>
		</article>
		<article class="bugs">
			<span>Bugs Squashed</span>
			<strong>287</strong>
			<button class="bug-icon-button" type="button" data-bug-squasher aria-label="Squash bug">
				<img class="alien-icon" src={alienIcon} alt="" width="64" height="50" loading="eager" />
			</button>
		</article>
	</div>
</Panel>

<style>
	.projects-panel {
		grid-column: 1 / -1;
	}

	.project-grid,
	.system-row {
		position: relative;
		z-index: 1;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: clamp(14px, 1.4vw, 22px);
	}

	.project-card {
		display: grid;
		grid-template-rows: auto 88px auto 1fr auto auto;
		min-height: 325px;
		border: 1px solid rgba(148, 183, 220, 0.28);
		border-radius: 6px;
		background:
			linear-gradient(180deg, rgba(9, 18, 31, 0.9), rgba(5, 11, 20, 0.96)),
			radial-gradient(circle at 70% 16%, rgba(95, 230, 255, 0.08), transparent 10rem);
		overflow: hidden;
		transition:
			transform 180ms ease,
			border-color 180ms ease,
			box-shadow 180ms ease;
	}

	.project-card:hover {
		transform: translateY(-4px);
		border-color: rgba(94, 255, 181, 0.56);
		box-shadow: 0 24px 55px rgba(0, 0, 0, 0.32);
	}

	.card-top,
	.project-card footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
	}

	.card-top {
		padding: 14px 16px 0;
		color: var(--yellow);
		font-size: clamp(0.62rem, 0.66vw, 0.74rem);
		font-weight: 800;
		text-transform: uppercase;
	}

	.badge {
		padding: 4px 7px;
		border: 1px solid currentColor;
		border-radius: 3px;
		color: var(--green);
		background: rgba(94, 255, 181, 0.08);
	}

	.badge.warning {
		color: var(--yellow);
		background: rgba(255, 227, 94, 0.08);
	}

	.badge.live {
		color: var(--green);
	}

	.badge.secret {
		color: var(--purple);
		background: rgba(182, 140, 255, 0.1);
	}

	.project-icon {
		display: grid;
		place-items: center;
		padding: 8px 18px 0;
	}

	.project-icon img {
		display: block;
		width: min(86px, 42%);
		max-height: 82px;
		object-fit: contain;
		filter: drop-shadow(0 0 14px rgba(95, 230, 255, 0.2));
	}

	h3 {
		margin: 0;
		padding: 0 18px;
		color: #fff;
		font-size: clamp(0.95rem, 1vw, 1.25rem);
		line-height: 1.2;
		text-transform: uppercase;
	}

	.project-card p {
		margin: 14px 0 0;
		padding: 0 18px;
		color: #c7d4e2;
		font-size: clamp(0.68rem, 0.74vw, 0.84rem);
		line-height: 1.58;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		padding: 18px;
	}

	.tags span {
		padding: 4px 6px;
		border: 1px solid rgba(148, 183, 220, 0.28);
		border-radius: 3px;
		color: #cdd8e6;
		background: rgba(255, 255, 255, 0.035);
		font-size: clamp(0.56rem, 0.62vw, 0.68rem);
	}

	.project-card footer {
		padding: 13px 18px;
		border-top: 1px solid rgba(148, 183, 220, 0.18);
		color: var(--muted);
		font-size: clamp(0.6rem, 0.66vw, 0.74rem);
		text-transform: uppercase;
	}

	.project-card footer strong {
		color: var(--green);
	}

	.project-links {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: flex-end;
		gap: 10px;
	}

	.project-links a {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		color: #cdd8e6;
		text-decoration: none;
		transition:
			color 160ms ease,
			transform 160ms ease;
	}

	.project-links a:hover,
	.project-links a:focus-visible {
		color: var(--green);
		transform: translateY(-1px);
	}

	.project-links a:focus-visible {
		outline: 1px solid rgba(94, 255, 181, 0.72);
		outline-offset: 4px;
	}

	.project-links :global(.pixel-icon) {
		--pixel-icon-size: 13px;
	}

	.system-row {
		display: grid;
		grid-template-columns: 1fr minmax(180px, 300px);
		gap: 14px;
		margin-top: 22px;
	}

	.feed,
	.bugs {
		border: 1px solid rgba(148, 183, 220, 0.24);
		border-radius: 5px;
		background: rgba(5, 12, 22, 0.76);
	}

	.feed {
		padding: 14px 18px;
		font-size: clamp(0.62rem, 0.68vw, 0.76rem);
	}

	.feed strong {
		display: block;
		margin-bottom: 8px;
		color: var(--green);
		text-transform: uppercase;
	}

	.feed p {
		margin: 0;
		color: #b8c8d8;
		line-height: 1.45;
	}

	.bugs {
		position: relative;
		display: grid;
		align-content: center;
		padding: 18px 96px 18px 22px;
		min-height: 80px;
	}

	.bugs span {
		color: var(--muted);
		font-size: 0.68rem;
		text-transform: uppercase;
	}

	.bugs strong {
		margin-top: 6px;
		color: var(--text);
		font-size: 1.45rem;
		font-weight: 500;
	}

	.bug-icon-button {
		position: absolute;
		top: 50%;
		right: 22px;
		display: grid;
		place-items: center;
		width: 70px;
		height: 56px;
		padding: 0;
		border: 0;
		background: transparent;
		transform: translateY(-50%);
	}

	.bug-icon-button::before {
		position: absolute;
		inset: 7px 6px;
		border-radius: 999px;
		content: "";
		background: rgba(94, 255, 181, 0.08);
		filter: blur(8px);
		opacity: 0;
		transform: scale(0.72);
		transition:
			opacity 160ms ease,
			transform 160ms ease;
	}

	.bug-icon-button .alien-icon {
		position: relative;
		width: 64px;
		height: auto;
		filter: drop-shadow(0 0 14px rgba(95, 230, 255, 0.24));
		transform-origin: 50% 84%;
		transition:
			filter 180ms ease,
			transform 180ms ease;
	}

	.bug-icon-button:hover::before,
	.bug-icon-button:focus-visible::before {
		opacity: 1;
		transform: scale(1);
	}

	.bug-icon-button:hover .alien-icon,
	.bug-icon-button:focus-visible .alien-icon {
		filter:
			drop-shadow(0 0 14px rgba(95, 230, 255, 0.32))
			drop-shadow(0 6px 0 rgba(94, 255, 181, 0.14));
		transform: translateY(-3px) rotate(-3deg);
	}

	.bug-icon-button:focus-visible {
		outline: 1px solid rgba(94, 255, 181, 0.72);
		outline-offset: 4px;
	}

	.bug-icon-button.is-squashing::before {
		animation: bug-burst 360ms ease-out;
	}

	.bug-icon-button.is-squashing .alien-icon {
		animation: bug-squash 360ms cubic-bezier(0.3, 0, 0.2, 1);
	}

	@media (max-width: 1420px) {
		.project-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 1180px) {
		.projects-panel {
			grid-column: auto;
		}
	}

	@media (max-width: 660px) {
		.project-grid,
		.system-row {
			grid-template-columns: 1fr;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.bug-icon-button::before,
		.bug-icon-button .alien-icon {
			transition: none;
		}

		.bug-icon-button:hover .alien-icon,
		.bug-icon-button:focus-visible .alien-icon {
			transform: translateY(-2px);
		}

		.bug-icon-button.is-squashing::before,
		.bug-icon-button.is-squashing .alien-icon {
			animation: none;
		}
	}

	@keyframes bug-squash {
		0%,
		100% {
			transform: translateY(-3px) scale(1) rotate(-3deg);
		}

		34% {
			transform: translateY(5px) scale(1.16, 0.62) rotate(0deg);
		}

		58% {
			transform: translateY(-8px) scale(0.84, 1.18) rotate(4deg);
		}

		78% {
			transform: translateY(1px) scale(1.04, 0.92) rotate(-2deg);
		}
	}

	@keyframes bug-burst {
		0% {
			opacity: 0.75;
			transform: scale(0.7);
		}

		100% {
			opacity: 0;
			transform: scale(1.35);
		}
	}
</style>

<script>
	document.addEventListener('click', ({ target }) => {
		if (!(target instanceof Element)) {
			return;
		}

		const button = target.closest<HTMLButtonElement>('[data-bug-squasher]');

		if (!button) {
			return;
		}

		const activeTimer = Number(button.dataset.animationTimer ?? 0);

		if (activeTimer) {
			window.clearTimeout(activeTimer);
		}

		button.classList.remove('is-squashing');
		void button.offsetWidth;
		button.classList.add('is-squashing');

		const timer = window.setTimeout(() => {
			button.classList.remove('is-squashing');
			delete button.dataset.animationTimer;
		}, 420);

		button.dataset.animationTimer = String(timer);
	});
</script>
