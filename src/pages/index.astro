---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroPanel from '../components/HeroPanel.astro';
import ProjectsPanel from '../components/ProjectsPanel.astro';
import SkillsPanel from '../components/SkillsPanel.astro';
import ExperiencePanel from '../components/ExperiencePanel.astro';
import HireTerminal from '../components/HireTerminal.astro';
import PixelIcon from '../components/PixelIcon.astro';

const externalLinkIcon = '/pixelarticons/external-link.svg';
const heartIcon = '/pixelarticons/heart.svg';
const linkIcon = '/pixelarticons/link.svg';
---

<Layout>
	<main class="portfolio-shell">
		<section class="dashboard" aria-label="Arib Farooqui portfolio command center">
			<div class="hero-area">
				<Header />
				<HeroPanel />
			</div>
			<ProjectsPanel />
			<SkillsPanel />
			<ExperiencePanel />
			<HireTerminal />
			<footer class="site-footer" aria-label="Portfolio footer">
				<div class="socials" aria-label="Social links">
					<a href="https://github.com/aribbabar" target="_blank" rel="noreferrer" aria-label="GitHub">
						<PixelIcon src={externalLinkIcon} />
					</a>
					<a
						href="https://www.linkedin.com/in/aribfarooqui/"
						target="_blank"
						rel="noreferrer"
						aria-label="LinkedIn"
					>
						<PixelIcon src={linkIcon} />
					</a>
				</div>
				<span class="built">Built with <PixelIcon src={heartIcon} class="footer-heart" /> and too much caffeine</span>
				<span>© 2026 Arib Farooqui. All rights reserved.</span>
			</footer>
		</section>
	</main>
</Layout>

<style>
	.portfolio-shell {
		min-height: 100svh;
		padding: 12px;
		overflow: hidden;
	}

	.dashboard {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		grid-auto-rows: auto;
		gap: 10px;
		max-width: 1900px;
		min-height: calc(100svh - 24px);
		margin: 0 auto;
	}

	.hero-area {
		position: relative;
		display: grid;
		grid-template-rows: 72px 1fr;
		min-width: 0;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(180deg, rgba(8, 16, 30, 0.9), rgba(4, 9, 18, 0.88)),
			radial-gradient(circle at 64% 34%, rgba(83, 231, 255, 0.12), transparent 22rem);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.025);
		overflow: hidden;
		min-height: clamp(580px, 72svh, 760px);
	}

	.site-footer {
		display: grid;
		justify-items: center;
		align-content: center;
		gap: 10px;
		min-width: 0;
		padding: 18px 28px;
		border: 1px solid rgba(148, 183, 220, 0.2);
		border-radius: 4px;
		background: rgba(7, 14, 27, 0.76);
		color: var(--faint);
		font-size: clamp(0.58rem, 0.68vw, 0.78rem);
		text-align: center;
		text-transform: uppercase;
	}

	.socials {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
	}

	.socials a {
		display: grid;
		place-items: center;
		width: 24px;
		aspect-ratio: 1;
		color: var(--muted);
		text-decoration: none;
		transition:
			color 160ms ease,
			transform 160ms ease;
	}

	.socials a:hover {
		color: var(--green);
		transform: translateY(-1px);
	}

	.socials a :global(.pixel-icon),
	.built :global(.pixel-icon) {
		--pixel-icon-size: 18px;
	}

	.built {
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.built :global(.footer-heart) {
		color: var(--green);
	}

	@media (max-width: 1180px) {
		.dashboard {
			grid-template-rows: auto;
		}

		.hero-area {
			min-height: 600px;
		}

		.site-footer {
			order: 20;
		}
	}

	@media (max-width: 680px) {
		.portfolio-shell {
			padding: 8px;
			overflow: visible;
		}

		.dashboard {
			gap: 8px;
			min-height: auto;
		}

		.hero-area {
			grid-template-rows: auto 1fr;
			min-height: auto;
		}

		.site-footer {
			padding: 16px;
		}
	}
</style>
