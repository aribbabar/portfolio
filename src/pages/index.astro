---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroPanel from '../components/HeroPanel.astro';
import ProjectsPanel from '../components/ProjectsPanel.astro';
import SkillsPanel from '../components/SkillsPanel.astro';
import ExperiencePanel from '../components/ExperiencePanel.astro';
import HireTerminal from '../components/HireTerminal.astro';
---

<Layout>
	<main class="portfolio-shell">
		<section class="dashboard" aria-label="Arib Farooqui portfolio command center">
			<div class="hero-area">
				<Header />
				<HeroPanel />
			</div>
			<SkillsPanel />
			<ProjectsPanel />
			<ExperiencePanel />
			<footer class="site-footer" aria-label="Portfolio footer">
				<div class="socials" aria-label="Social links">
					<a href="https://github.com/aribfarooqui" aria-label="GitHub">GH</a>
					<a href="https://www.linkedin.com/" aria-label="LinkedIn">IN</a>
					<a href="mailto:hello@arib.dev" aria-label="Email">ME</a>
				</div>
				<span>© 2026 Arib Farooqui. All rights reserved.</span>
				<span>Built with &lt;3 and too much caffeine</span>
			</footer>
			<HireTerminal />
		</section>
	</main>
</Layout>

<style>
	.portfolio-shell {
		min-height: 100svh;
		padding: 12px;
		overflow: hidden;
	}

	.dashboard {
		display: grid;
		grid-template-columns: minmax(0, 1.68fr) minmax(360px, 0.96fr);
		grid-template-rows: minmax(425px, 52vh) auto auto 42px;
		gap: 10px;
		max-width: 1900px;
		min-height: calc(100svh - 24px);
		margin: 0 auto;
	}

	.hero-area {
		display: grid;
		grid-template-rows: 72px 1fr;
		min-width: 0;
		border: 1px solid var(--line);
		border-radius: var(--radius);
		background:
			linear-gradient(180deg, rgba(8, 16, 30, 0.94), rgba(4, 9, 18, 0.9)),
			radial-gradient(circle at 64% 34%, rgba(83, 231, 255, 0.12), transparent 22rem);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.025);
		overflow: hidden;
	}

	.site-footer {
		grid-column: 1 / 2;
		display: grid;
		grid-template-columns: 190px 1fr auto;
		align-items: center;
		gap: 18px;
		min-width: 0;
		padding: 0 28px;
		border: 1px solid rgba(148, 183, 220, 0.2);
		border-radius: 4px;
		background: rgba(7, 14, 27, 0.76);
		color: var(--faint);
		font-size: clamp(0.58rem, 0.68vw, 0.78rem);
		text-transform: uppercase;
	}

	.socials {
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.socials a {
		color: var(--muted);
		text-decoration: none;
		transition:
			color 160ms ease,
			transform 160ms ease;
	}

	.socials a:hover {
		color: var(--green);
		transform: translateY(-1px);
	}

	@media (max-width: 1180px) {
		.dashboard {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
		}

		.hero-area {
			min-height: 640px;
		}

		.site-footer {
			grid-column: auto;
			order: 20;
		}
	}

	@media (max-width: 680px) {
		.portfolio-shell {
			padding: 8px;
			overflow: visible;
		}

		.dashboard {
			gap: 8px;
			min-height: auto;
		}

		.hero-area {
			grid-template-rows: auto 1fr;
			min-height: 720px;
		}

		.site-footer {
			grid-template-columns: 1fr;
			justify-items: center;
			padding: 16px;
			text-align: center;
		}
	}
</style>
