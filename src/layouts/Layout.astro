---
import {
	DEFAULT_SOCIAL_IMAGE,
	SITE_AUTHOR,
	SITE_DESCRIPTION,
	SITE_KEYWORDS,
	SITE_NAME,
	SITE_SOCIALS,
	SITE_TITLE,
	getCanonicalUrl,
	getSiteUrl,
} from '../lib/seo';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image = DEFAULT_SOCIAL_IMAGE,
	noindex = false,
} = Astro.props;

const siteUrl = getSiteUrl(Astro.site);
const canonicalUrl = getCanonicalUrl(Astro.url.pathname, Astro.site);
const socialImageUrl = new URL(image, `${siteUrl}/`).toString();
const robots = noindex ? 'noindex, nofollow' : 'index, follow';
const jsonLd = [
	{
		'@context': 'https://schema.org',
		'@type': 'Person',
		'@id': `${siteUrl}/#person`,
		name: SITE_AUTHOR,
		jobTitle: 'Software Engineer',
		url: siteUrl,
		image: socialImageUrl,
		sameAs: SITE_SOCIALS,
		knowsAbout: SITE_KEYWORDS.slice(1, -1),
		worksFor: {
			'@type': 'Organization',
			name: 'Impresset Business Services',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
		'@id': `${siteUrl}/#website`,
		name: SITE_NAME,
		url: siteUrl,
		description,
		author: {
			'@id': `${siteUrl}/#person`,
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'WebPage',
		'@id': `${canonicalUrl}#webpage`,
		url: canonicalUrl,
		name: title,
		description,
		isPartOf: {
			'@id': `${siteUrl}/#website`,
		},
		about: {
			'@id': `${siteUrl}/#person`,
		},
		mainEntity: {
			'@id': `${siteUrl}/#person`,
		},
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="author" content={SITE_AUTHOR} />
		<meta name="keywords" content={SITE_KEYWORDS.join(', ')} />
		<meta name="robots" content={robots} />
		<meta name="theme-color" content="#030811" />
		<meta name="color-scheme" content="dark" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={SITE_NAME} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={socialImageUrl} />
		<meta property="og:image:alt" content="Arib Farooqui software engineer portfolio preview" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={socialImageUrl} />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<script is:inline>
			document.documentElement.dataset.consoleEgg = 'armed';
			console.log(
				'%c> access granted: portfolio console',
				'color: #030811; background: #5effb5; font-weight: 800; padding: 3px 6px;',
			);
			console.groupCollapsed(
				'%cconsole side quest',
				'color: #5effb5; font-weight: 800; font-size: 13px;',
			);
			console.log(
				'%cYou opened DevTools. That means you are either debugging, hiring, or avoiding a task. Respect.',
				'color: #eff7ff;',
			);
			console.log(
				'%cTry this on the page terminal: easter-egg',
				'color: #5fe6ff; font-weight: 700;',
			);
			console.log(
				'%cSecret status: the CSS is pretending it had a plan all along.',
				'color: #ffe35e;',
			);
			console.groupEnd();
		</script>
	</body>
</html>

<style is:global>
	:root {
		color-scheme: dark;
		--bg: #030811;
		--panel: rgba(7, 14, 27, 0.86);
		--panel-strong: rgba(8, 16, 29, 0.96);
		--line: rgba(148, 183, 220, 0.28);
		--line-bright: rgba(116, 255, 199, 0.72);
		--text: #eff7ff;
		--muted: #9aaabd;
		--faint: #607184;
		--green: #5effb5;
		--green-soft: rgba(94, 255, 181, 0.16);
		--cyan: #5fe6ff;
		--purple: #b68cff;
		--yellow: #ffe35e;
		--orange: #ff9d52;
		--red: #ff655c;
		--radius: 8px;
		--mono: "Cascadia Code", "SFMono-Regular", Consolas, "Liberation Mono", monospace;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background:
			radial-gradient(circle at 20% 8%, rgba(44, 120, 255, 0.15), transparent 30rem),
			radial-gradient(circle at 78% 18%, rgba(88, 255, 187, 0.1), transparent 24rem),
			linear-gradient(180deg, #02060e 0%, #07101d 52%, #040812 100%);
		color: var(--text);
		font-family: var(--mono);
		font-size: 16px;
	}

	* {
		box-sizing: border-box;
		cursor: default;
	}

	button,
	a {
		font: inherit;
	}

	a {
		color: inherit;
	}

	::selection {
		background: rgba(94, 255, 181, 0.32);
	}

	body::before {
		position: fixed;
		inset: 0;
		z-index: -2;
		content: "";
		background-image:
			linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
			linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
		background-size: 58px 58px;
		mask-image: linear-gradient(to bottom, transparent, black 15%, black 78%, transparent);
	}

	body::after {
		position: fixed;
		inset: 0;
		z-index: 5;
		pointer-events: none;
		content: "";
		background:
			linear-gradient(rgba(255, 255, 255, 0.025) 50%, transparent 50%) 0 0 / 100% 4px,
			radial-gradient(circle at center, transparent 0, rgba(0, 0, 0, 0.24) 100%);
		mix-blend-mode: screen;
		opacity: 0.32;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>
